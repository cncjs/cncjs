// Landing View
.landing-view {
  display: flex;
  flex-direction: column;
  gap: 15px;
  padding: 10px 0;
}

.path-card {
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 15px;
  background-color: #f9f9f9;

  &:hover {
    background-color: #f5f5f5;
  }
}

.path-title {
  display: flex;
  align-items: center;
  column-gap: 4px;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #333;
}

.path-description {
  font-size: 12px;
  color: #666;
  margin-bottom: 12px;
  line-height: 1.4;
}

.landing-tip {
  display: flex;
  align-items: flex-start;
  padding: 10px;
  background-color: #fffbeb;
  border: 1px solid #fde68a;
  border-radius: 4px;
  font-size: 12px;
  color: #92400e;
}

.tip-icon {
  font-size: 16px;
  margin-right: 8px;
  flex-shrink: 0;
}

.tip-text {
  line-height: 1.4;
}
