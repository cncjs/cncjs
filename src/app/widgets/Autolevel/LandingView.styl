// Landing View
.landing-view {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.path-card {
  border: 1px solid #ddd;
  padding: 15px;
  background-color: #f9f9f9;

  &:hover {
    background-color: #f5f5f5;
  }
}

.path-title {
  display: flex;
  align-items: center;
  column-gap: 4px;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #333;
}

.path-description {
  font-size: 12px;
  color: #666;
  margin-bottom: 12px;
  line-height: 1.4;
}

