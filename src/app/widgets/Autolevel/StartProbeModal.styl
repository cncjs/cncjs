// Warning Box (Start Probe Modal)
.warning-box {
  padding: 12px;
  background-color: #fff3cd;
  border: 1px solid #ffc107;
  border-radius: 4px;
  margin: 15px 0;
}

.warning-title {
  font-weight: 600;
  font-size: 13px;
  color: #856404;
  margin-bottom: 8px;
}

.warning-content {
  font-size: 12px;
  color: #856404;

  p {
    margin: 8px 0;
  }

  ul {
    margin: 8px 0;
    padding-left: 20px;
    list-style: none;

    li {
      margin: 4px 0;
    }
  }
}
