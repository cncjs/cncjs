// Setup Probe View
.setup-probe-view {
  padding: 5px 0;
}

.section-header {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid #e0e0e0;
  color: #333;
}

.section {
  margin-bottom: 15px;
}

.section {
  &:last-child {
    margin-bottom: 0;
  }
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #555;
}

.grid-info {
  display: flex;
  align-items: center;
  height: 100%;
  font-size: 12px;
  color: #666;
  padding: 8px;
  background-color: #f5f5f5;
  border-radius: 4px;
}

.area-info {
  font-size: 11px;
  color: #666;
  padding: 6px 8px;
  background-color: #f9f9f9;
  border-radius: 4px;
  margin-top: 8px;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;

  .btn {
    flex: 1 1 auto;
  }
}

.navigation-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 12px;
  margin-top: 12px;
  border-top: 1px solid #e0e0e0;
}

// Form adjustments
.form-group {
  margin-bottom: 10px;

  label.control-label {
    font-size: 11px;
    margin-bottom: 4px;
  }

  small.text-muted {
    font-size: 10px;
    display: block;
    margin-top: 2px;
  }
}
