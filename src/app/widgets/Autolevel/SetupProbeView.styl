// Setup Probe View
.setup-probe-view {
  padding: 5px 0;
}

.section-header {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid #e0e0e0;
  color: #333;
}

.section {
  margin-bottom: 15px;
}

.section {
  &:last-child {
    margin-bottom: 0;
  }
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #555;
}

// Form adjustments
.form-group {
  margin-bottom: 10px;

  label.control-label {
    font-size: 11px;
    margin-bottom: 4px;
  }

  small.text-muted {
    font-size: 10px;
    display: block;
    margin-top: 2px;
  }
}
