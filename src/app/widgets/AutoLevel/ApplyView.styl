// Apply View
.apply-view {
  padding: 5px 0;
}

.section-header {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid #e0e0e0;
  color: #333;
  letter-spacing: 0.5px;
}

.section {
  margin-bottom: 15px;
}

.section-title {
  font-size: 12px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #555;
  border-bottom: 1px solid #e8e8e8;
  padding-bottom: 4px;
}

// Probe data info
.probe-data-info {
  padding: 10px;
  background-color: #f9f9f9;
  border-radius: 4px;
  font-size: 12px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;

  &:last-child {
    margin-bottom: 0;
  }
}

.info-label {
  color: #666;
}

.info-value {
  font-weight: 500;
  color: #333;
}

// No G-code state
.no-gcode-section {
  text-align: center;
  padding: 20px 10px;
}

.no-gcode-text {
  color: #666;
  font-size: 13px;
  margin-bottom: 8px;
}

.load-prompt {
  color: #888;
  font-size: 11px;
  margin-bottom: 5px;
}

// G-code loaded state
.file-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.file-info {
  font-size: 12px;
  padding: 8px;
  background-color: #f5f5f5;
  border-radius: 4px;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.gcode-toggle {
  margin: 10px 0;
  font-size: 12px;

  label {
    cursor: pointer;
    user-select: none;
    display: block;
    margin-bottom: 5px;

    input[type="radio"] {
      margin-right: 4px;
    }
  }
}

.gcode-info {
  font-size: 11px;
  color: #666;
  margin-top: 8px;
}

.loading-message {
  font-size: 12px;
  color: #0275d8;
  padding: 8px;
  background-color: #f0f7ff;
  border-radius: 4px;
  text-align: center;
  margin-top: 8px;
}

// Success message
.success-message {
  font-size: 12px;
  color: #5cb85c;
  padding: 8px;
  background-color: #f0f8f0;
  border-radius: 4px;
  text-align: center;
}

// Action buttons (side by side)
.action-buttons {
  display: flex;
  gap: 8px;

  button {
    flex: 1;
    white-space: normal;
    height: auto;
    padding: 8px 4px;
    line-height: 1.3;
  }
}

// Navigation
.navigation-footer {
  display: flex;
  justify-content: flex-start;
  padding-top: 12px;
  margin-top: 12px;
  border-top: 1px solid #e0e0e0;
}

.no-data {
  text-align: center;
  padding: 20px;
  color: #999;
  font-style: italic;
  font-size: 12px;
}
